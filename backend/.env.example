# --- core ---
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./agripilot.db
ACCESS_TOKEN_EXPIRE_HOURS=24

# --- mock mode ---
# true  = no external API calls; realistic fake results (same philosophy as the frontend)
# false = call real services; any service whose key is missing still falls back to mock
MOCK_MODE=true

# --- Gemini (vision analysis + Bangla speech-to-text) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- ElevenLabs (Bangla text-to-speech for report audio) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- OpenWeather (weather intelligence) ---
OPENWEATHER_API_KEY=
# default field location: Bogura, Rajshahi
WEATHER_LAT=24.85
WEATHER_LON=89.37
WEATHER_REGION_NAME=Bogura, Rajshahi
